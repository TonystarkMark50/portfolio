{
  "name": "portfolio-strapi",
  "private": true,
  "version": "0.1.0",
  "description": "Portfolio CMS backend powered by Strapi",
  "scripts": {
    "develop": "strapi develop",
    "start": "strapi start",
    "build": "strapi build && node -e \"const{cpSync,readdirSync,rmSync}=require('fs');const{join}=require('path');cpSync('src','dist/src',{recursive:true,filter:f=>require('fs').statSync(f).isDirectory()||f.endsWith('.json')});readdirSync('dist/config').filter(f=>f.endsWith('.d.ts')).forEach(f=>rmSync(join('dist/config',f)))\"",
    "strapi": "strapi"
  },
  "dependencies": {
    "@strapi/plugin-cloud": "5.49.0",
    "@strapi/plugin-users-permissions": "5.49.0",
    "@strapi/strapi": "5.49.0",
    "better-sqlite3": "12.11.1",
    "pg": "8.22.0",
    "pg-connection-string": "2.14.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "tailwindcss": "^3.4.17"
  },
  "engines": {
    "node": ">=18.0.0 <=22.x.x"
  }
}
