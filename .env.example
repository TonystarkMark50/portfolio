# Strapi Headless CMS Configuration
# Local: VITE_STRAPI_URL=http://localhost:1337
# Cloud (Render/Railway): VITE_STRAPI_URL=https://your-app.onrender.com
# When set, the frontend fetches data from Strapi instead of Supabase.
VITE_STRAPI_URL=http://localhost:1337

# Supabase (fallback for now, can be removed after Strapi migration)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
